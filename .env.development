# Environment
NODE_ENV="development"
PORT=3000
API_URL="http://localhost:3000"
CORS_ORIGIN="http://localhost:3000"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# Logging
LOG_LEVEL="debug"