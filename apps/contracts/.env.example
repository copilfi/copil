# Deployment Configuration
PRIVATE_KEY=your_private_key_here
ADMIN_PRIVATE_KEY=your_admin_private_key_here

# Network RPC URLs
SEI_TESTNET_RPC_URL=https://evm-rpc-testnet.sei-apis.com
SEI_RPC_URL=https://evm-rpc.sei-apis.com

# Block Explorer API Key for contract verification
SEI_ETHERSCAN_API_KEY=your_seitrace_api_key_here

# Gas Reporting (optional)
REPORT_GAS=false
COINMARKETCAP_API_KEY=your_coinmarketcap_api_key_here

# Deployment Configuration
DEPLOYER_ADDRESS=your_deployer_address_here
ADMIN_ADDRESS=your_admin_address_here